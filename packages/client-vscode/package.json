{
	"name": "vscode-lsl-lsp",
	"displayName": "LSL LSP",
	"description": "LSL (Linden Scripting Language) support with #include/#ifdef, semantics, and diagnostics.",
	"version": "0.1.17",
	"license": "MIT",
	"publisher": "Sekkmer",
	"author": {
		"name": "Sekkmer",
		"email": "sekkmer@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/sekkmer/lsl-lsp.git"
	},
	"engines": {
		"vscode": "^1.90.0"
	},
	"icon": "media/icon.png",
	"categories": [
		"Programming Languages"
	],
	"keywords": [
		"lsl",
		"linden",
		"secondlife",
		"language server",
		"lsp",
		"syntax",
		"formatter"
	],
	"galleryBanner": {
		"color": "#0B1220",
		"theme": "dark"
	},
	"main": "./out/extension.js",
	"activationEvents": [],
	"contributes": {
		"languages": [
			{
				"id": "lsl",
				"aliases": [
					"LSL",
					"lsl"
				],
				"extensions": [
					".lsl",
					".lslp",
					".lsli",
					".lslh"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "lsl",
				"scopeName": "source.lsl",
				"path": "./syntaxes/lsl.tmLanguage.json"
			}
		],
		"commands": [
			{ "command": "lsl.showServerLogs", "title": "Show Language Server Trace", "category": "LSL" },
			{ "command": "lsl.showClientLogs", "title": "Show Client Logs", "category": "LSL" },
			{ "command": "lsl.restartServer", "title": "Restart Language Server", "category": "LSL" },
			{ "command": "lsl.clearCaches", "title": "Clear Caches", "category": "LSL" },
			{ "command": "lsl.updateDefinitions", "title": "Update Definitions", "category": "LSL" },
			{ "command": "lsl.useBundledDefinitions", "title": "Use Bundled Definitions", "category": "LSL" },
			{ "command": "lsl.showActiveDefinitions", "title": "Show Active Definitions", "category": "LSL" },
			{ "command": "lsl.openPreprocessedScript", "title": "Open Preprocessed Script", "category": "LSL" },
			{ "command": "lsl.openOptimizedScript", "title": "Open Optimized Script", "category": "LSL" },
			{ "command": "lsl.openFirestormOriginalSource", "title": "Open Firestorm Original Source", "category": "LSL" },
			{ "command": "lsl.buildServer", "title": "Build Server (repo task)", "category": "LSL" }
		],
		"menus": {
			"editor/context": [
				{
					"command": "lsl.openPreprocessedScript",
					"when": "editorLangId == lsl",
					"group": "navigation@20"
				},
				{
					"command": "lsl.openOptimizedScript",
					"when": "editorLangId == lsl",
					"group": "navigation@21"
				},
				{
					"command": "lsl.openFirestormOriginalSource",
					"when": "editorLangId == lsl",
					"group": "navigation@22"
				}
			]
		},
		"configuration": {
			"title": "LSL",
			"properties": {
				"lsl.definitionsPath": {
					"type": "string",
					"default": "",
					"description": "Path to LSL definition file (JSON/YAML). Leave empty to use the bundled official definitions."
				},
				"lsl.definitions.autoUpdate": {
					"type": "boolean",
					"default": true,
					"description": "Automatically download and use validated official LSL definition updates when no custom definitionsPath is configured."
				},
				"lsl.definitions.updateUrl": {
					"type": "string",
					"default": "https://raw.githubusercontent.com/secondlife/lsl-definitions/main/lsl_definitions.yaml",
					"description": "Source URL for automatic official LSL definition updates."
				},
				"lsl.definitions.updateIntervalHours": {
					"type": "number",
					"default": 24,
					"minimum": 0,
					"description": "Minimum time between automatic LSL definition update checks. Set to 0 to check on every activation."
				},
				"lsl.includePaths": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Additional include search paths for #include. The workspace folder(s) are searched by default. Order: current file directory → workspace roots → these paths."
				},
				"lsl.macros": {
					"type": "object",
					"default": {},
					"description": "Project-wide predefined macros for #ifdef."
				},
				"lsl.dynamicMacros": {
					"type": "array",
					"items": { "type": "string" },
					"default": [],
					"description": "Macros to preserve as typed dynamic values, using name:type entries such as __AGENTID__:string."
				},
				"lsl.extensions": {
					"type": "object",
					"default": {},
					"additionalProperties": false,
					"description": "Off-by-default LSL dialect extensions accepted by the parser and lowered to standard LSL when rendering preprocessed or optimized output.",
					"properties": {
						"switch": { "type": "boolean", "default": false },
						"lazyLists": { "type": "boolean", "default": false },
						"constGlobalExpressions": { "type": "boolean", "default": false }
					}
				},
				"lsl.optimize": {
					"type": "object",
					"default": {},
					"additionalProperties": false,
					"description": "Optimizer feature switches. All optimizer features are enabled by default; set individual flags to false to disable them.",
					"properties": {
						"constantFold": { "type": "boolean", "default": true },
						"dropDefaultInitializers": { "type": "boolean", "default": true },
						"dropNoOpCasts": { "type": "boolean", "default": true },
						"foldStringConcats": { "type": "boolean", "default": true },
						"inlineConstantGlobals": { "type": "boolean", "default": true },
						"inlineFunctions": { "type": "boolean", "default": true },
						"integerPeepholes": { "type": "boolean", "default": true },
						"bitwiseBooleanOps": { "type": "boolean", "default": true },
						"listAdd": { "type": "boolean", "default": true },
						"removeUnusedFunctions": { "type": "boolean", "default": true },
						"shrinkNames": { "type": "boolean", "default": true }
					}
				},
				"lsl.output.firestormHeaderForOptimized": {
					"type": "boolean",
					"default": false,
					"description": "Prefix generated optimized output with a Firestorm-compatible reversible original-source header."
				},
				"lsl.measure.inlayHints": {
					"type": "boolean",
					"default": true,
					"description": "Show an inlay hint at the script state with estimated Mono free memory, optimized free memory, and the calibrated error band."
				},
				"lsl.enableSemanticTokens": {
					"type": "boolean",
					"default": true
				},
				"lsl.debugLogging": {
					"type": "boolean",
					"default": false,
					"description": "Enable verbose LSL extension logging in the Output panel (LSL Debug)."
				},
				"lsl.diagnostics.disable": {
					"type": "array",
					"items": { "type": "string" },
					"default": [],
					"markdownDescription": "Diagnostic codes or friendly names to suppress globally. Accepts values like `LSL101`, `unused-param`, `return_in_void`. Names are case-insensitive; dash/underscore interchangeable."
				},
				"lsl.trace": {
					"type": "string",
					"enum": ["off", "messages", "verbose"],
					"default": "off",
					"description": "Language client protocol trace level. Off by default."
				}
			}
		}
	},
	"dependencies": {
		"vscode-languageclient": "^9.0.1"
	},
	"devDependencies": {
		"@lsl-lsp/core": "workspace:*",
		"@types/node": "^24.12.4",
		"@types/vscode": "^1.90.0",
		"@vscode/vsce": "^3.9.1",
		"esbuild": "0.28.0",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"bundle": "esbuild src/extension.ts --bundle --platform=node --target=node18 --external:vscode --outfile=out/extension.js --sourcemap",
		"bundle:server": "esbuild ../server/src/index.ts --bundle --platform=node --target=node18 --outfile=server/out/index.js --sourcemap",
		"vscode:prepublish": "pnpm -C ../core build && pnpm -C ../server build && node scripts/copy-server.cjs && pnpm run bundle:server && pnpm run bundle",
		"package": "pnpm exec vsce package --no-dependencies",
		"publish": "pnpm exec vsce publish",
		"watch": "tsc -w -p tsconfig.json",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix"
	}
}
